# Copy to .env and fill in real values. .env is git-ignored — never commit secrets.
# This file documents WHICH variables exist, not their values.

# --- PostgreSQL ---
DATABASE_URL=postgresql://acx:acx@localhost:5432/acx

# --- Ingestion API auth (Phase 3) ---
# Static API token the connector presents to the ingestion API.
ACX_API_TOKEN=replace-with-long-random-string

# --- AWS (Phases 1-2) ---
# Credentials come from the least-privilege IAM user, NOT the root account.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_RECORDINGS_BUCKET=
SQS_QUEUE_URL=
SQS_DLQ_URL=

# --- Processing (Phase 4) ---
WHISPER_MODEL=base
