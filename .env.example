# Copy to .env and fill in real values. .env is git-ignored — never commit secrets.
# This file documents WHICH variables exist, not their values.

# --- PostgreSQL ---
DATABASE_URL=postgresql://acx:acx@localhost:5432/acx

# --- Ingestion API auth (Phase 3) ---
# Static API token the connector presents to the ingestion API.
ACX_API_TOKEN=replace-with-long-random-string

# --- AWS admin creds (Phase 2 provisioning ONLY) ---
# Used by infra/aws/*.py to CREATE resources. These are powerful; delete at teardown.
# Mint via IAM console for the andy-admin user (CLI access key).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_RECORDINGS_BUCKET=
SQS_QUEUE_URL=
SQS_DLQ_URL=

# --- Connector runtime creds (least-privilege; Phase 2) ---
# Created by infra/aws/provision_connector_iam.py for the acx-connector IAM user.
# Scoped to consume the queue + read recording/CTR objects, nothing else.
CONNECTOR_AWS_ACCESS_KEY_ID=
CONNECTOR_AWS_SECRET_ACCESS_KEY=

# --- Processing (Phase 4) ---
WHISPER_MODEL=base
